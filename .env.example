# Copy to .env and fill in. Never commit the real .env.
# Required — cognee's LLM + embedding key (default provider: OpenAI).
# OPENAI_API_KEY works too (cognee_setup.py aliases it to LLM_API_KEY).
LLM_API_KEY=

# Optional overrides (leave commented unless needed):
# LLM_PROVIDER=openai
# LLM_MODEL=openai/gpt-5-mini
# This project defaults to text-embedding-3-small (low-tier OpenAI projects
# rate-limit 3-large hard); uncomment to override:
# EMBEDDING_MODEL=openai/text-embedding-3-large

# --- Optional: Cognee Cloud mode -------------------------------------
# COGNEE_CLOUD=true runs remember/recall/improve/forget on a hosted Cognee
# instance instead of locally — much faster ingestion (the LLM graph
# extraction runs on their infra; no LLM_API_KEY needed in this mode).
# The graph visualization panel is local-mode only.
COGNEE_CLOUD=false
COGNEE_API_KEY=
COGNEE_BASE_URL=
COGNEE_TENANT_ID=

# Optional, cloud mode only: persist the patient registry in MySQL (AWS RDS)
# instead of the local patients.db, so hosted redeploys keep their state.
# Needs global-bundle.pem (AWS RDS CA, committed in this repo) or DB_SSL_CA.
# If set but unreachable (e.g. RDS security group blocks your laptop), the
# app warns once and falls back to SQLite.
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_DATABASE=